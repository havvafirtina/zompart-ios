    "scan.subtitle" : {
      "extractionState" : "stale",
      "localizations" : {
        "en" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Take a photo of the broken or worn part and our AI will identify it. You can also add a text description for better accuracy. We'll find the best prices from multiple vendors."
          }
        },
        "sv" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Ta ett foto av den trasiga eller slitna delen och vår AI identifierar den. Du kan också lägga till en textbeskrivning för bättre träffsäkerhet. Vi hittar de bästa priserna från flera leverantörer."
          }
        },
        "tr" : {
          "stringUnit" : {
            "state" : "translated",
            "value" : "Kırık veya yıpranmış parçanın fotoğrafını çekin, AI'mız tanımlasın. Daha doğru sonuç için yazılı açıklama da ekleyebilirsiniz. Birden fazla satıcıdan en iyi fiyatları bulacağız."
          }
        }
      }
